from fastapi import APIRouter, Query, UploadFile, File, HTTPException
from typing import Optional
from app.services.locator.locator_stocks import get_stock_summary, get_sales_funnel_summary
from app.services.locator.locator_calc import calc_article_dl, calc_irp_il
from app.services.locator.locator_geo_report import parse_geo_report, get_geo_size_dl, get_geo_size_dl_list
from app.services.locator.locator_stocks_report import init_stocks_report_db, parse_stocks_report, save_stocks_report
from collections import defaultdict

router = APIRouter(prefix="/api/locator", tags=["locator"])

@router.get("/summary")
async def locator_summary(force_refresh: bool = Query(False)):
    funnel = get_sales_funnel_summary(days=28, force_refresh=force_refresh)
    stocks = get_stock_summary(force_refresh=force_refresh)
    articles = []
    for f in funnel:
        vendor = f.get("vendorCode")
        if vendor and vendor in stocks:
            art = calc_article_dl(stocks[vendor], f)
            articles.append(art)
    irp_il = calc_irp_il(articles)
    return {
        "il": irp_il["il"],
        "irp": irp_il["irp"],
        "totalOrders4w": irp_il["totalOrders"],
        "articles": articles,
        "updatedAt": None,
    }

@router.get("/dl")
async def locator_dl(force_refresh: bool = Query(False)):
    import sqlite3
    from pathlib import Path
    from collections import defaultdict
    DB_PATH = Path("/root/wb-analytics/backend/locator_cache.db")
    
    # 1. Данные из stocks_size_report
    stocks_report = {}
    with sqlite3.connect(str(DB_PATH)) as conn:
        conn.row_factory = sqlite3.Row
        cur = conn.execute("SELECT nm_id, size, orders_qty, buyout_qty, stock_total, buyout_pct FROM stocks_size_report")
        for row in cur.fetchall():
            key = f"{row['nm_id']}_{row['size']}"
            stocks_report[key] = {
                "orders_qty": row["orders_qty"],
                "buyout_qty": row["buyout_qty"],
                "stock_total": row["stock_total"],
                "buyout_pct": row["buyout_pct"],
            }
    
    # 2. Данные из geo_size_dl (ДЛ по размерам)
    geo_data = get_geo_size_dl()
    dl_by_size = {}
    for g in geo_data:
        nm_id = g.get("nm_id")
        size = g.get("size")
        if nm_id and size:
            key = f"{nm_id}_{size}"
            if key not in dl_by_size:
                dl_by_size[key] = {"total_orders": 0, "total_local": 0}
            dl_by_size[key]["total_orders"] += g.get("orders_total", 0)
            dl_by_size[key]["total_local"] += g.get("orders_local", 0)
    
    # 3. Группируем по артикулам
    articles_dict = defaultdict(lambda: {
        "orders4w": 0,
        "buyouts4w": 0,
        "totalStock": 0,
        "local_orders": 0,
        "sizes": {}
    })
    
    for key, data in stocks_report.items():
        nm_id, size = key.split("_", 1)
        orders = data["orders_qty"]
        buyouts = data["buyout_qty"]
        stock = data["stock_total"]
        buyout_pct = data["buyout_pct"]
        
        # ДЛ для этого размера
        dl = 0
        size_key = f"{nm_id}_{size}"
        if size_key in dl_by_size and dl_by_size[size_key]["total_orders"] > 0:
            dl = round(dl_by_size[size_key]["total_local"] / dl_by_size[size_key]["total_orders"] * 100, 2)
        
        articles_dict[nm_id]["orders4w"] += orders
        articles_dict[nm_id]["buyouts4w"] += buyouts
        articles_dict[nm_id]["totalStock"] += stock
        articles_dict[nm_id]["local_orders"] += int(orders * dl / 100) if dl > 0 else 0
        
        articles_dict[nm_id]["sizes"][size] = {
            "orders4w": orders,
            "buyoutPercent": buyout_pct,
            "stock": stock,
            "daysToOOS": round(stock / max(orders / 28, 0.01), 1) if orders > 0 else 999,
            "dl": dl,
        }
    
    # 4. Формируем результат
    result = []
    total_orders = sum(art["orders4w"] for art in articles_dict.values())
    
    for nm_id, art in articles_dict.items():
        buyout_pct_article = round(art["buyouts4w"] / art["orders4w"] * 100, 1) if art["orders4w"] > 0 else 0
        il_weight = round(art["orders4w"] / total_orders * 100, 2) if total_orders > 0 else 0
        dl_article = round(art["local_orders"] / art["orders4w"] * 100, 1) if art["orders4w"] > 0 else 0
        
        sorted_sizes = dict(sorted(art["sizes"].items(), key=lambda x: int(x[0]) if x[0].isdigit() else 0))
        result.append({
            "vendorCode": nm_id,
            "nmId": nm_id,
            "dl": dl_article,
            "orders4w": art["orders4w"],
            "buyoutPercent": buyout_pct_article,
            "totalStock": art["totalStock"],
            "daysToOOS": round(art["totalStock"] / max(art["orders4w"] / 28, 0.01), 1) if art["orders4w"] > 0 else 999,
            "ilWeight": il_weight,
            "sizes": sorted_sizes,
        })
    
    result.sort(key=lambda x: -x["ilWeight"])
    return {"articles": result}

@router.get("/alerts")
async def locator_alerts(force_refresh: bool = Query(False)):
    import sqlite3
    from pathlib import Path
    DB_PATH = Path("/root/wb-analytics/backend/locator_cache.db")
    
    alerts = []
    with sqlite3.connect(str(DB_PATH)) as conn:
        conn.row_factory = sqlite3.Row
        cur = conn.execute("SELECT nm_id, size, stock_total, orders_qty FROM stocks_size_report WHERE orders_qty > 0")
        for row in cur.fetchall():
            if row["stock_total"] == 0:
                alerts.append({
                    "type": "CRITICAL_ZERO",
                    "severity": "HIGH",
                    "message": f"{row['nm_id']} размер {row['size']}: 0 остатков (заказов: {row['orders_qty']})"
                })
            elif row["stock_total"] > 20:
                alerts.append({
                    "type": "OVERSTOCK",
                    "severity": "MEDIUM",
                    "message": f"{row['nm_id']} размер {row['size']}: перетарка {row['stock_total']} шт"
                })
    
    return {"alerts": alerts, "total": len(alerts)}

@router.post("/import-geo")
async def import_geo(file: UploadFile = File(...)):
    try:
        contents = await file.read()
        rows = parse_geo_report(contents)
        return {"status": "ok", "rowsSaved": rows}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@router.post("/import-stocks")
async def import_stocks(file: UploadFile = File(...)):
    try:
        contents = await file.read()
        init_stocks_report_db()
        parsed = parse_stocks_report(contents)
        save_stocks_report(parsed["summary"], parsed["warehouse"])
        return {"status": "ok", "rowsSaved": len(parsed["summary"])}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@router.get("/dl-real")
async def locator_dl_real(force_refresh: bool = Query(False)):
    rows = get_geo_size_dl_list()
    return {"articles": rows}
